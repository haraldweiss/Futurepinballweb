{
  "name": "futurepinball-web",
  "version": "0.16.0",
  "description": "Modern cross-platform browser-based 3D pinball game with VPX-competitive graphics and physics",
  "author": "Future Pinball Contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron-main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite src",
    "build": "vite build",
    "preview": "vite preview --outDir dist",
    "start": "node start-game.js",
    "start:1": "node start-game.js 1",
    "start:2": "node start-game.js 2",
    "start:3": "node start-game.js 3",
    "start:auto": "node start-game.js auto",
    "install:setup": "node installer.js",
    "install:check": "node installer.js --check-only",
    "electron-dev": "electron . --inspect",
    "electron-build": "npm run build && electron-builder",
    "electron-dist": "npm run build && electron-builder --publish never",
    "electron-win": "npm run build && electron-builder --win",
    "electron-mac": "npm run build && electron-builder --mac",
    "electron-linux": "npm run build && electron-builder --linux",
    "test:security": "tsx src/test-security.ts",
    "lint:security": "eslint src --config .eslintrc.security.json --fix",
    "audit:dependencies": "npm audit --audit-level=moderate",
    "security:check": "npm run lint:security && npm run test:security && npm run audit:dependencies"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "0.12.0",
    "cfb": "1.2.2",
    "three": "0.162.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-no-unsanitized": "^4.0.2",
    "eslint-plugin-security": "^2.1.0",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-is-dev": "latest",
    "electron-updater": "latest",
    "tsx": "^4.6.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.1"
  },

  "build": {
    "appId": "com.futurepinball.web",
    "productName": "Future Pinball Web",
    "files": [
      "dist/**/*",
      "electron-main.js",
      "electron-preload.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": ["sha256"]
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Future Pinball Web",
      "installerIcon": "public/icons/icon-256x256.png",
      "uninstallerIcon": "public/icons/icon-256x256.png"
    },

    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },

    "dmg": {
      "contents": [
        {
          "x": 110,
          "y": 150,
          "type": "file"
        },
        {
          "x": 240,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },

    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    },

    "appImage": {
      "artifactName": "${productName}-${version}.${ext}"
    },

    "deb": {
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
