{
  "name": "futurepinball-web",
  "version": "0.20.2",
  "description": "Modern cross-platform browser-based 3D pinball game with VPX-competitive graphics and physics",
  "author": {
    "name": "Future Pinball Contributors",
    "email": "noreply@futurepinball.invalid"
  },
  "license": "MIT",
  "type": "module",
  "main": "electron-main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite src",
    "build": "vite build",
    "preview": "vite preview --outDir dist",
    "serve": "node server.js",
    "start": "node start-game.js",
    "start:1": "node start-game.js 1",
    "start:2": "node start-game.js 2",
    "start:3": "node start-game.js 3",
    "start:auto": "node start-game.js auto",
    "stop": "node stop-game.js",
    "stop:force": "node stop-game.js --force",
    "install:setup": "node installer.js",
    "install:check": "node installer.js --check-only",
    "electron-dev": "electron . --inspect",
    "electron-build": "npm run build && electron-builder",
    "electron-dist": "npm run build && electron-builder --publish never",
    "electron-win": "npm run build && electron-builder --win",
    "electron-mac": "npm run build && electron-builder --mac",
    "electron-linux": "npm run build && electron-builder --linux",
    "test:security": "tsx src/test-security.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:security": "eslint src --config .eslintrc.security.json --fix",
    "audit:dependencies": "npm audit --audit-level=moderate",
    "security:check": "npm run lint:security && npm run test:security && npm run audit:dependencies"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "0.12.0",
    "cfb": "1.2.2",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.0",
    "three": "0.162.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^4.1.4",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-no-unsanitized": "~4.0.2",
    "eslint-plugin-security": "^2.1.0",
    "happy-dom": "^20.8.9",
    "tsx": "^4.6.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.futurepinball.web",
    "productName": "Future Pinball Web",
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "electron-preload.cjs",
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "haraldweiss",
      "repo": "Futurepinballweb",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Future Pinball Web"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game"
    },
    "appImage": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
